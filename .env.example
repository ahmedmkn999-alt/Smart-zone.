# انسخ الملف ده لـ .env.local واملأ القيم الحقيقية — .env.local متتبعتش على Git أبدًا

# قاعدة البيانات (SQLite للتجربة المحلية — استبدلها بـ Postgres في البرودكشن)
DATABASE_URL="file:./dev.db"

# مفتاح توقيع الـ JWT — لازم يكون Random string طويل (32+ حرف). ولّده بـ:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# مفتاح تشفير الكودات (HMAC pepper) — لازم يكون سري ومختلف عن JWT_SECRET
CODE_PEPPER="CHANGE_ME_TO_ANOTHER_LONG_RANDOM_SECRET"

# مفتاح تجزئة بصمة الجهاز (Device Fingerprint) — مختلف عن باقي الأسرار
DEVICE_PEPPER="CHANGE_ME_TO_ANOTHER_LONG_RANDOM_SECRET"

# مفتاح التشفير العام (AES-256-GCM) لأي بيانات حساسة تانية — لازم يكون 32 بايت بالظبط (base64)
# ولّده بـ: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="CHANGE_ME_32_BYTE_BASE64_KEY"

# CSRF secret
CSRF_SECRET="CHANGE_ME_TO_ANOTHER_LONG_RANDOM_SECRET"

# دومين الموقع (لازم يتظبط صح في البرودكشن عشان الكوكيز الـ Secure تشتغل)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# أول أدمن يتعمل وقت الـ seed
ADMIN_SEED_EMAIL="admin@smartzone.local"
ADMIN_SEED_PASSWORD="ChangeThisPassword123!"

# اختياري: قفل لوحة التحكم على IP معيّن بس (افصل بينهم بفاصلة). سيبها فاضية لو مش عايز القفل ده
ADMIN_IP_ALLOWLIST=""
